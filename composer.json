{
  "name": "tuusuario/examen-recu-vvs",
  "description": "Kata para el examen de recuperación VVS",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "lint": "phpcs --standard=PSR12 src tests"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "ExamenRecuVvs\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ExamenRecuVvs\\Test\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true
  },
  "scripts": {
    "test": [
      "phpunit --configuration phpunit.xml"
    ]
  }
}